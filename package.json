{
  "name": "romm-client",
  "version": "0.1.0",
  "description": "Browse and download ROMs from your RomM server on Steam Deck",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tarek/decky-romm-client.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "romm",
    "roms",
    "steam-deck"
  ],
  "author": "tarek",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/tarek/decky-romm-client/issues"
  },
  "homepage": "https://github.com/tarek/decky-romm-client#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.1",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
